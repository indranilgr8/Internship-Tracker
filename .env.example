# Gmail SMTP credentials used to send the daily digest.
# Use a Google "App Password" (requires 2FA enabled), NOT your normal password.
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Who receives the digest email (can be the same as GMAIL_ADDRESS)
RECIPIENT_EMAIL=recipient@example.com

# Path to the SQLite database file
DATABASE_PATH=internships.db

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: how many days out counts as "expiring soon" in the digest/dashboard
EXPIRING_SOON_DAYS=3
